# generated by the Python interpreter or build tools).
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Python virtual environments — pearl_vllm_cpu/.venv etc.
# Use uv/pip/poetry to recreate from the project's requirements.
.venv/
venv/
env/
ENV/

# Profiling output
f1_profile_*.json.gz
*.prof

# Local model weights / checkpoints (large binaries; obtained out of
