+fn bazel_nix_clangxx() -> Option<std::path::PathBuf> {
+    let cxx = std::env::var_os("CXX")?;
+    if std::path::Path::new(&cxx)
+        .file_name()
+        .and_then(|name| name.to_str())
+        != Some("cc_wrapper.sh")
+    {
+        return None;
+    }
+
+    std::env::var_os("PATH").and_then(|path| {
+        std::env::split_paths(&path)
+            .map(|dir| dir.join("clangxx-with-sysroot"))
+            .find(|candidate| candidate.is_file())
+    })
+}
