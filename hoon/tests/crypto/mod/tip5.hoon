=<
|%
++  test-tip5-fixlen
  %+  expect-eq  !>(%.y)
  !>
  %+  roll  tip5-fixlen-kats
  |=  [tv=tip5-tv acc=?]
  ^-  ?
  &(acc =((~(hash-10 tip5 5) input.tv) output.tv))
::
++  test-tip5-varlen
  %+  expect-eq  !>(%.y)
  !>
  %+  roll  tip5-varlen-kats
  |=  [tv=tip5-tv acc=?]
  ^-  ?
  &(acc =((~(hash-varlen tip5 5) input.tv) output.tv))
--
::
|%
