      gift  assets.coinbase
      recipient  p:default-keys-2:h
      parent-hash  (hash:nnote:t coinbase)
    ==
  =/  seed2=seed:t
    %*  .  *seed:t
      gift  0
      recipient  p:default-keys-3:h
      parent-hash  (hash:nnote:t coinbase)
    ==
  =/  inp=$>(%0 input:t)
    ($:new:v0:input:t coinbase (~(put z-in *seeds:t) seed1) 0 s:default-keys-1:h)
  ::
  ::  input is bad because signature only commits to seed1 and not seed1 and seed2
  ?>  ?=(%0 -.inp)
  =.  seeds.spend.inp  (~(put z-in seeds.spend.inp) seed2)
  =/  ips=inputs:t  (new:v0:inputs:t inp)
  %+  expect-eq  !>(~)
  !>((mole |.((from-inputs:v0:raw-tx:t ips))))
