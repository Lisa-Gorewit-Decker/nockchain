        gift=1
        hash=(hash:nnote:t coinbase)
    ==
  =.  sed1  sed1(output-source `[(hash:seed:t sed1) %.n])
  =/  sed2=seed:t
    %:  simple:new:seed:t
        recipient=recipient2
        gift=2
        hash=(hash:nnote:t coinbase)
    ==
  =.  sed2  sed2(output-source `[(hash:seed:t sed1) %.n])
  =/  seds=seeds:t  (new:seeds:t ~[sed1 sed2])
  =/  inp=$>(%0 input:t)  ($:new:v0:input:t coinbase seds 0 s:default-keys-1:h)
  =/  inps=inputs:t  (new:v0:inputs:t inp)
  =/  succ=(unit raw-tx:t)  (mole |.((from-inputs:v0:raw-tx:t inps)))
  ?~  succ
    !!
  =/  transaction=(unit tx:t)  (mole |.((new:tx:t u.succ 1)))
  ?~  transaction
    !!
  %+  expect-eq
    !>(%.n)
  !>((validate:tx:t u.transaction))
