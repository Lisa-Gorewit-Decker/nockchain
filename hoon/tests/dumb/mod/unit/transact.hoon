::
++  test-spend-fee
  =/  con=consensus-state  initial-consensus-state:h
  =^  par=page:t  con  (add-n-pages:h 101 con default-retain:h)
  ::
  =/  new-page=page:t  (make-empty-page:h par)
  =/  coinb=coinbase:t  make-default-coinbase:v0:h
  ?>  ?=(^ -.coinb)
  =/  fees=coins:t  1
  =/  raw=raw-tx:t
    %:  with-refund:simple-from-note:new:raw-tx:v0:t
        recipient=p:default-keys-2:h
        gift=1
        fees
        not=coinb
        sk=s:default-keys-1:h
    ==
  =/  =tx:t  (new:tx:t raw 102)
  ?>  ?=(^ -.raw-tx.tx)
  =.  new-page
    ?^  -.new-page
      %=  new-page
        tx-ids  (~(put z-in *(z-set tx-id:t)) ~(id get:raw-tx:t raw-tx.tx))
      ==
    %=  new-page
      tx-ids  (~(put z-in *(z-set tx-id:t)) ~(id get:raw-tx:t raw-tx.tx))
    ==
  =/  total-coinbase-assets=coins:t
    (add (emission-calc:coinbase:t ~(height get:page:t new-page)) ~(total-fees get:tx:t tx))
  =.  new-page
    ?^  -.new-page
      %=  new-page
        coinbase  (new:v0:coinbase-split:t total-coinbase-assets default-keys-1-share:h)
      ==
    %=  new-page
      coinbase  (new:v1:coinbase-split:t total-coinbase-assets default-keys-1-share-v1:h)
    ==
  =.  new-page
    ?^  -.new-page
      %=  new-page
        digest  (compute-digest:page:t new-page)
      ==
    %=  new-page
      digest  (compute-digest:page:t new-page)
    ==
  =^  ready  con  (~(add-raw-tx dcon con constants) raw-tx.tx)
  ?>  -:(~(validate-page-without-txs dcon con constants) new-page ~(timestamp get:page:t new-page))
  =/  tac  (~(validate-page-with-txs dcon con constants) new-page)
  ?:  ?=(%.n -.tac)
    (expect !>(%.n))
  =.  con  (~(accept-page dcon con constants) new-page +.tac *@da)
  =.  con  (~(update-heaviest dcon con constants) new-page)
  =/  old-in-balance=?
    (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t make-default-coinbase:v0:h))
  =/  outs=outputs:t  ~(outputs get:tx:t tx)
  ?>  ?=(%0 -.outs)
  =/  new-note=nnote:t
    note:(~(got z-by +.outs) p:default-keys-2:h)
  ?>  ?=(^ -.new-note)
  =/  new-in-balance=?
    (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t new-note))
  =/  new-coinb=coinbase:t
    (new:v0:coinbase:t new-page p:default-keys-1:h)
  %+  expect-eq
    !>  :*  %.n
            %.y
            new-coinb
            (~(got z-by =<(+ ~(coinbase get:page:t new-page))) p:default-keys-1:h)
        ==
  !>  :*  old-in-balance
          new-in-balance
          (~(got h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t new-coinb))
          assets:(~(got h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t new-coinb))
      ==
::
::  given i hear tx at height two, when i hear one more page, pending
::  state is unchanged
++  test-pending-tx-retain-1-page
  =/  con=consensus-state  initial-consensus-state:h
  =^  new-page=page:t  con  (add-n-pages:h 1 con default-retain:h)
  ::  we hear a new tx
  =/  =tx:t  (new:tx:t (make-default-coinbase-raw-tx:v0:h p:default-keys-2:h) 2)
  =/  raw=raw-tx:t  raw-tx.tx
  =^  ready  con  (~(add-raw-tx dcon con constants) raw)
  =/  expect-pending-blocks  pending-blocks.con
  =^  par=page:t  con  (add-n-pages:h 1 con (some 20))
  %+  expect-eq
    !>(expect-pending-blocks)
  !>(pending-blocks.con)
::
::  given i hear tx at height two, when i hear one fewer page than the
::  tx GC window, pending state is unchanged
++  test-pending-tx-retain-before-gc
  =/  con=consensus-state  initial-consensus-state:h
  =^  new-page=page:t  con  (add-n-pages:h 1 con default-retain:h)
  ::  we hear a new tx
  =/  =tx:t  (new:tx:t (make-default-coinbase-raw-tx:v0:h p:default-keys-2:h) 2)
  =/  raw=raw-tx:t  raw-tx.tx
  =^  ready  con  (~(add-raw-tx dcon con constants) raw)
  =/  expect-raw-txs  raw-txs.con
  =/  expect-excluded-txs  excluded-txs.con
  ::  add one fewer page than the tx gc window to hit edge case
  =^  new-page=page:t  con  (add-n-pages:h (dec default-tx-gc-retain:h) con default-retain:h)
  ;:  weld
    %+  expect-eq
      !>(expect-raw-txs)
    !>(raw-txs.con)
  ::
    %+  expect-eq
      !>(expect-excluded-txs)
    !>(excluded-txs.con)
  ==
::
::  given i hear tx at height two, when i hear the tx GC window's worth
::  of pages, pending state is the same as it was before i heard that tx.
++  test-pending-tx-dont-retain-at-gc
  =/  con=consensus-state  initial-consensus-state:h
  =^  new-page=page:t  con  (add-n-pages:h 1 con default-retain:h)
  ::  we hear a new tx
  =/  =tx:t  (new:tx:t (make-default-coinbase-raw-tx:v0:h p:default-keys-2:h) 2)
  =/  raw=raw-tx:t  raw-tx.tx
  ::
  =/  expect-raw-txs  raw-txs.con
  =/  expect-excluded-txs  excluded-txs.con
  =^  ready  con  (~(add-raw-tx dcon con constants) raw)
  ::  add the tx gc window's worth of pages to hit the edge
  =^  new-page=page:t  con  (add-n-pages:h default-tx-gc-retain:h con default-retain:h)
  ;:  weld
    %+  expect-eq
      !>(expect-raw-txs)
    !>(raw-txs.con)
  ::
    %+  expect-eq
      !>(expect-excluded-txs)
    !>(excluded-txs.con)
  ==
::
::  given i hear tx at height two and our pending tx retainment policy is
::  to get rid of them every time i hear a new block, when i hear a new block
::  the pending state is as it was before i heard the tx.
++  test-pending-tx-never-retain
  =/  con=consensus-state  initial-consensus-state:h
  =^  new-page=page:t  con  (add-n-pages:h 1 con default-retain:h)
  ::  we hear a new tx
  =/  =tx:t  (new:tx:t (make-default-coinbase-raw-tx:v0:h p:default-keys-2:h) 2)
  =/  raw=raw-tx:t  raw-tx.tx
  ::
  =/  expect-raw-txs  raw-txs.con
  =/  expect-excluded-txs  excluded-txs.con
  =^  ready  con  (~(add-raw-tx dcon con constants) raw)
  =^  new-page=page:t  con  (add-n-pages:h 1 con (some 0))
  ;:  weld
    %+  expect-eq
      !>(expect-raw-txs)
    !>(raw-txs.con)
  ::
    %+  expect-eq
      !>(expect-excluded-txs)
    !>(excluded-txs.con)
  ==
::
::  given i hear tx at height two and block retention is unbounded, when i hear
::  fewer pages than the tx GC window the pending state still has that tx
++  test-pending-tx-unbounded-retain-before-gc
  =/  con=consensus-state  initial-consensus-state:h
  =^  new-page=page:t  con  (add-n-pages:h 1 con default-retain:h)
  ::  we hear a new tx
  =/  =tx:t  (new:tx:t (make-default-coinbase-raw-tx:v0:h p:default-keys-2:h) 2)
  =/  raw=raw-tx:t  raw-tx.tx
  =^  ready  con  (~(add-raw-tx dcon con constants) raw)
  =/  expect-raw-txs  raw-txs.con
  =/  expect-excluded-txs  excluded-txs.con
  =^  par=page:t  con  (add-n-pages:h (dec default-tx-gc-retain:h) con ~)
  ;:  weld
    %+  expect-eq
      !>(expect-raw-txs)
    !>(raw-txs.con)
  ::
    %+  expect-eq
      !>(expect-excluded-txs)
    !>(excluded-txs.con)
  ==
