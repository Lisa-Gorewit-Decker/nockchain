++  test-two-to-three-utxo-spend
  =/  con=consensus-state  initial-consensus-state:h
  =^  page1=page:t  con  (add-n-pages:h 1 con default-retain:h)
  =/  coin1=coinbase:t  (new:v0:coinbase:t page1 p:default-keys-1:h)
  ?>  ?=(^ -.coin1)
  =^  page2=page:t  con  (add-n-pages:h 1 con default-retain:h)
  =/  coin2=coinbase:t  (new:v0:coinbase:t page2 p:default-keys-1:h)
  ?>  ?=(^ -.coin2)
  =^  last-page=page:t  con  (add-n-pages:h 101 con default-retain:h)
  ::
  =/  seed2=seed:t
    %*  .  *seed:t
      gift  (dec assets.coin2)
      recipient  p:default-keys-3:h
      parent-hash  (hash:nnote:t coin2)
    ==
  =/  seed3=seed:t
    %*  .  *seed:t
      gift  1
      recipient  p:default-keys-1:h
      parent-hash  (hash:nnote:t coin2)
    ==
  ::  two inputs -> three outputs
  =/  inp1=$>(%0 input:t)
    (simple-from-note:new:v0:input:t p:default-keys-2:h coin1 s:default-keys-1:h)
  =/  inp2=$>(%0 input:t)  ($:new:v0:input:t coin2 (~(gas z-in *seeds:t) ~[seed2 seed3]) 0 s:default-keys-1:h)
  =/  ips=inputs:t  (multi:new:v0:inputs:t ~[inp1 inp2])
  =/  raw=raw-tx:t  (from-inputs:v0:raw-tx:t ips)
  ::
  =/  new-page=page:t  (make-empty-page:h last-page)
  =/  =tx:t  (new:tx:t raw ~(height get:page:t new-page))
  ?>  ?=(^ -.raw-tx.tx)
  =.  new-page
    ?^  -.new-page
      %=  new-page
        tx-ids  (~(put z-in *(z-set tx-id:t)) ~(id get:raw-tx:t raw-tx.tx))
      ==
    %=  new-page
      tx-ids  (~(put z-in *(z-set tx-id:t)) ~(id get:raw-tx:t raw-tx.tx))
    ==
  =.  new-page
    ?^  -.new-page
      %=  new-page
        digest  (compute-digest:page:t new-page)
      ==
    %=  new-page
      digest  (compute-digest:page:t new-page)
    ==
  =^  ready  con  (~(add-raw-tx dcon con constants) raw-tx.tx)
  ?>  -:(~(validate-page-without-txs dcon con constants) new-page ~(timestamp get:page:t new-page))
  ::
  =/  tac  (~(validate-page-with-txs dcon con constants) new-page)
  ?:  ?=(%.n -.tac)  (expect !>(%.n))
  =.  con  (~(accept-page dcon con constants) new-page +.tac *@da)
  =.  con  (~(update-heaviest dcon con constants) new-page)
  =/  old-in-balance=?
    ?|  (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t coin1))
        (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t coin2))
    ==
  =/  outs=outputs:t  ~(outputs get:tx:t tx)
  ?>  ?=(%0 -.outs)
  =/  new-note1=nnote:t
    note:(~(got z-by +.outs) p:default-keys-2:h)
  =/  new-note2=nnote:t
    note:(~(got z-by +.outs) p:default-keys-3:h)
  =/  new-note3=nnote:t
    note:(~(got z-by +.outs) p:default-keys-1:h)
  ?>  ?=(^ -.new-note1)
  ?>  ?=(^ -.new-note2)
  ?>  ?=(^ -.new-note3)
  =/  new-in-balance=?
    ?&  (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t new-note1))
        (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t new-note2))
        (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t new-note3))
    ==
  %+  expect-eq
    !>  [%.n %.y assets.coin1 (dec assets.coin2) 1]
  !>  :*  old-in-balance
          new-in-balance
          assets.new-note1
          assets.new-note2
          assets.new-note3
      ==
