      recipient=p:default-keys-2:h
      gift=1
      fee=0
      note=coinbase
      refund-address=p:default-keys-3:h
    ==
  =/  seedz=(list seed:t)  ~(tap z-in seds)
  ?>  =(1 (lent seedz))
  =/  sed=seed:t  (head seedz)
  %+  expect-eq
    !>(%.y)
  !>  ?&  =(gift:sed 1)
          =(parent-hash:sed (hash:nnote:t coinbase))
          =(recipient.sed p:default-keys-2:h)
