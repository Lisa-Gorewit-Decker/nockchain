    (join:sig:t 2 ~[p:default-keys-1:h p:default-keys-2:h p:default-keys-3:h])
  =/  =tx:t  (new:tx:t (make-default-coinbase-raw-tx:v0:h sig) 102)
  ?>  ?=(^ -.raw-tx.tx)
  =.  new-page
