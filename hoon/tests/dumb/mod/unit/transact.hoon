::
++  test-two-valid-transactions-in-one-block
  =/  con=consensus-state  initial-consensus-state:h
  =^  page1=page:t  con  (add-n-pages:h 1 con default-retain:h)
  =/  coin1=coinbase:t  (new:v0:coinbase:t page1 p:default-keys-1:h)
  ?>  ?=(^ -.coin1)
  =^  page2=page:t  con  (add-n-pages:h 1 con default-retain:h)
  =/  coin2=coinbase:t  (new:v0:coinbase:t page2 p:default-keys-1:h)
  ?>  ?=(^ -.coin2)
  =^  last-page=page:t  con  (add-n-pages:h 101 con default-retain:h)
  ::
  ::  first transaction: coin1 to keys-2
  =/  raw1=raw-tx:t
    (simple-from-note:new:raw-tx:v0:t p:default-keys-2:h coin1 s:default-keys-1:h)
  ::  second transaction: coin2 to keys-3
  =/  raw2=raw-tx:t
    (simple-from-note:new:raw-tx:v0:t p:default-keys-3:h coin2 s:default-keys-1:h)
  ::  create new page with both transactions
  =/  new-page=page:t  (make-empty-page:h last-page)
  =/  tx1=tx:t  (new:tx:t raw1 ~(height get:page:t new-page))
  =/  tx2=tx:t  (new:tx:t raw2 ~(height get:page:t new-page))
  ?>  ?=(^ -.raw-tx.tx1)
  ?>  ?=(^ -.raw-tx.tx2)
  =.  new-page
    ?^  -.new-page
      %=  new-page
        tx-ids  (~(gas z-in *(z-set tx-id:t)) ~[id.raw-tx.tx1 id.raw-tx.tx2])
      ==
    %=  new-page
      tx-ids  (~(gas z-in *(z-set tx-id:t)) ~[id.raw-tx.tx1 id.raw-tx.tx2])
    ==
  =.  new-page
    ?^  -.new-page
      %=  new-page
        digest  (compute-digest:page:t new-page)
      ==
    %=  new-page
      digest  (compute-digest:page:t new-page)
    ==
  =^  ready  con  (~(add-raw-tx dcon con constants) raw-tx.tx1)
  =^  ready  con  (~(add-raw-tx dcon con constants) raw-tx.tx2)
  ?>  -:(~(validate-page-without-txs dcon con constants) new-page ~(timestamp get:page:t new-page))
  ::  validate and add the new page
  =/  tac  (~(validate-page-with-txs dcon con constants) new-page)
  ?:  ?=(%.n -.tac)  (expect !>(%.n))
  =.  con  (~(accept-page dcon con constants) new-page +.tac *@da)
  =.  con  (~(update-heaviest dcon con constants) new-page)
  ::  check balances
  =/  old-in-balance=?
    ?|  (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t coin1))
        (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t coin2))
    ==
  =/  outs1=outputs:t  ~(outputs get:tx:t tx1)
  =/  outs2=outputs:t  ~(outputs get:tx:t tx2)
  ?>  ?=(%0 -.outs1)
  ?>  ?=(%0 -.outs2)
  =/  new-note1=nnote:t
    note:(~(got z-by +.outs1) p:default-keys-2:h)
  =/  new-note2=nnote:t
    note:(~(got z-by +.outs2) p:default-keys-3:h)
  ?>  ?=(^ -.new-note1)
  ?>  ?=(^ -.new-note2)
  =/  new-in-balance=?
    ?&  (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t new-note1))
        (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t new-note2))
    ==
  %+  expect-eq
    !>  [%.n %.y assets.coin1 assets.coin2]
  !>  :*  old-in-balance
          new-in-balance
          assets.new-note1
          assets.new-note2
      ==
::
++  test-add-tx-to-candidate-block
  =/  con=consensus-state  initial-consensus-state:h
  =^  par=page:t  con  (add-n-pages:h 101 con default-retain:h)
  ::
  ::  create a new empty candidate block
  =/  min=mining-state  initial-mining-state:h
  =.  min  (~(heard-new-block dmin min constants) con *@da)
  =/  raw=raw-tx:t  (make-default-coinbase-raw-tx:v0:h p:default-keys-2:h)
  ?>  ?=(^ -.raw)
  =.  min  (~(heard-new-tx dmin min constants) raw)
  %+  expect-eq
    !>(%.y)
  !>((~(has z-in ~(tx-ids get:page:t candidate-block.min)) ~(id get:raw-tx:t raw)))
::
++  test-fail-add-double-spend-to-candidate-block
  =/  con=consensus-state  initial-consensus-state:h
  =^  par=page:t  con  (add-n-pages:h 101 con default-retain:h)
  ::
  ::  create a new empty candidate block
  =/  min=mining-state  initial-mining-state:h
  =.  min  (~(heard-new-block dmin min constants) con *@da)
  ::
  =/  raw1=raw-tx:t  (make-default-coinbase-raw-tx:v0:h p:default-keys-2:h)
  =/  raw2=raw-tx:t  (make-default-coinbase-raw-tx:v0:h p:default-keys-3:h)
  ?>  ?=(^ -.raw1)
  ?>  ?=(^ -.raw2)
  =.  min  (~(heard-new-tx dmin min constants) raw1)
  =.  min  (~(heard-new-tx dmin min constants) raw2)
  %+  expect-eq
    !>  [%.y %.n]
  !>  :-  (~(has z-in ~(tx-ids get:page:t candidate-block.min)) ~(id get:raw-tx:t raw1))
      (~(has z-in ~(tx-ids get:page:t candidate-block.min)) ~(id get:raw-tx:t raw2))
::
::  a transaction with no inputs should fail unless its a coinbase. this
::  tests that such a tx will be rejected by the miner module
++  test-zero-utxo-tx-fail-candidate-block
  =/  con=consensus-state  initial-consensus-state:h
  =^  par=page:t  con  (add-n-pages:h 1 con default-retain:h)
  ::
  =/  min=mining-state  initial-mining-state:h
  =.  min  (~(heard-new-block dmin min constants) con *@da)
  ::
  =|  raw=raw-tx:v0:t
  =/  expect-min  min
  =.  min  (~(heard-new-tx dmin min constants) raw)
  %+  expect-eq  :: mining state should not change
    !>(expect-min)
  !>(min)
::
::  if we hear a zero utxo tx over the wire, it should be rejected
++  test-zero-utxo-tx-fail-validation
  =|  raw=raw-tx:v0:t
  ?>  ?=(^ -.raw)
  =.  id.raw  (compute-id:raw-tx:t raw)
  %+  expect-eq
    !>(%.n)
  :: this is the first check in +heard-tx in the kernel after the id check
  !>((validate:raw-tx:t raw))
::
::  if we hear a block with a zero utxo tx, we should reject it
++  test-zero-utxo-tx-block-reject
  =/  con=consensus-state  initial-consensus-state:h
  =^  par=page:t  con  (add-n-pages:h 1 con default-retain:h)
  ::
  =/  new-page=page:t  (make-empty-page:h par)
  =|  raw=raw-tx:v0:t
  ?>  ?=(^ -.raw)
  =.  id.raw  (compute-id:raw-tx:t raw)
  =^  ready  con  (~(add-raw-tx dcon con constants) raw)
  =.  new-page
    ?^  -.new-page
      %=  new-page
        tx-ids  (~(put z-in *(z-set tx-id:t)) ~(id get:raw-tx:t raw))
      ==
    %=  new-page
      tx-ids  (~(put z-in *(z-set tx-id:t)) ~(id get:raw-tx:t raw))
    ==
  =.  new-page
    ?^  -.new-page
      %=  new-page
        digest  (compute-digest:page:t new-page)
      ==
    %=  new-page
      digest  (compute-digest:page:t new-page)
    ==
  =/  tac=(reason tx-acc:t)
    (~(validate-page-with-txs dcon con constants) new-page)
  %+  expect-eq  !>(%.n)
  !>(-:tac)
::
++  test-valid-signed-spend
  =/  =coinbase:t  make-default-coinbase:v0:h
  ?>  ?=(^ -.coinbase)
