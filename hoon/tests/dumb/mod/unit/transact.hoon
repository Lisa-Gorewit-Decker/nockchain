/=  dcon  /apps/dumbnet/lib/consensus
/=  dmin  /apps/dumbnet/lib/miner
/=  *  /apps/dumbnet/lib/types
/=  *  /common/zeke
/=  *  /common/h-zoon
/=  tx-engine  /common/tx-engine
/=  *  /common/test
/=  helpers  /tests/dumb/helpers
::
|_  constants=_bc-v0-phase:helpers
+*  t  ~(. tx-engine constants)
    h  ~(. helpers constants)
++  test-add-genesis-page
  =/  con=consensus-state  initial-consensus-state:h
  ::
  =/  balance-expect  *(h-mip block-id:t nname:t nnote:t)
  =/  txs-expect  *(h-mip block-id:t tx-id:t tx:t)
  =/  blocks-expect
    %+  ~(put h-by *(h-map block-id:t local-page:t))
    default-genesis-id:h  (to-local-page:page:t default-genesis-page:h)
  =/  heaviest-expect  (some default-genesis-id:h)
  =/  min-timestamps-expect
    %+  ~(put h-by *(h-map block-id:t @))
    default-genesis-id:h  (time-in-secs:page:t *@da)
  =/  epoch-start-expect
    %+  ~(put h-by *(h-map block-id:t block-id:t))
    default-genesis-id:h  default-genesis-id:h
  =/  target-expect
    %+  ~(put h-by *(h-map block-id:t bignum:bignum))
    default-genesis-id:h  genesis-target:t
  =/  btc-data-expect  ``*btc-hash:t
  =/  genesis-seal-expect  `[0 (from-b58:hash:t default-genesis-seal:h)]
  =/  con-expect=consensus-state
    %*  .  *consensus-state
      balance  balance-expect
      txs      txs-expect
      blocks   blocks-expect
      heaviest-block  heaviest-expect
      min-timestamps  min-timestamps-expect
      epoch-start  epoch-start-expect
      targets  target-expect
      btc-data  btc-data-expect
      genesis-seal  genesis-seal-expect
    ==
  ::
  %+  expect-eq  !>(con-expect)
  !>(con)
::
++  test-spend-coinbase-before-timelock
  =/  con=consensus-state  initial-consensus-state:h
  =^  new-page=page:t  con  (add-n-pages:h 1 con default-retain:h)
  ::
  =/  =tx:t  (new:tx:t (make-default-coinbase-raw-tx:v0:h p:default-keys-2:h) 2)
  =/  tac=tx-acc:t  (new:tx-acc:t (~(get h-by balance.con) ~(digest get:page:t new-page)) 2)
  =/  res=(reason tx-acc:t)  (process:tx-acc:t tac raw-tx.tx)
  %+  expect-eq  !>(%.n)
  !>(-.res)
::
++  test-exceeds-max-block-size-one
  =.  constants  bc-max-block-one:helpers
  =/  con=consensus-state  initial-consensus-state:h
  =/  last-page=page:t
    (to-page:local-page:t (~(got h-by blocks.con) (need heaviest-block.con)))
  =/  new-page  (make-empty-page:h last-page)
  %+  expect-eq
    !>([%.n %block-too-large])
  !>((~(validate-page-with-txs dcon con constants) new-page))
::
++  test-exceeds-medium-block-size
  =.  constants  bc-max-block-size-medium-v0:helpers
  =/  con=consensus-state  initial-consensus-state:h
  =/  min=mining-state  initial-mining-state:h
  =/  curr-page=page:t  default-genesis-page:h
  =|  [i=@ txs=(list raw-tx:t)]
  ::
  =/  [con=consensus-state min=mining-state txs=(list raw-tx:t)]
    |-
    ?:  =(50 i)
      [con min txs]
    =/  new-page  (make-empty-page:h curr-page)
    =/  r=(reason tx-acc:t)  (~(validate-page-with-txs dcon con constants) new-page)
    ?.  ?=(%.y -.r)
      ~&  failed-reason++.r  !!
    =/  acc=tx-acc:t  +.r
    =.  con  (~(accept-page dcon con constants) new-page acc *@da)
    =.  con  (~(update-heaviest dcon con constants) new-page)
    =.  con  (~(garbage-collect dcon con constants) default-retain:h)
    =.  min  (~(heard-new-block dmin min constants) con *@da)
    =/  =coinbase:t  (new:v0:coinbase:t new-page p:default-keys-1:h)
    ?>  ?=(^ -.coinbase)
    =/  raw  (simple-from-note:new:raw-tx:v0:t p:default-keys-2:h coinbase s:default-keys-1:h)
    $(i +(i), curr-page new-page, txs [raw txs], con con, min min)
  =/  attempt-add=(unit mining-state)
    %-  mole
    |.
    %+  roll
      txs
    |=  [=raw-tx:t min=_min]
    =/  new-min  (~(heard-new-tx dmin min constants) raw-tx)
    ::  We are asserting that the mining state has changed here
    ::  If it hasn't changed, that means that adding the raw-tx
    ::  causes the block size to exceed the limit.
    ?<  =(new-min min)
    new-min
  ::
  ::  attempting to add the transactions should fail
  ::  because the block size exceeds the limit
  ?>  ?=(~ attempt-add)
  ~
::
++  test-raw-tx-not-based
  =/  con=consensus-state  initial-consensus-state:h
  =^  page1=page:t  con  (add-n-pages:h 1 con default-retain:h)
  =/  coin1=coinbase:t  (new:v0:coinbase:t page1 p:default-keys-1:h)
  ?>  ?=(^ -.coin1)
  ::
  ::  create raw-tx to twiddle
  =/  raw1=raw-tx:t
    (simple-from-note:new:raw-tx:v0:t p:default-keys-2:h coin1 s:default-keys-1:h)
  ::
  ::  twiddle id to be out of field, this would not be a valid raw-tx
  ::  generated by new:v0:raw-tx. we are checking if someone is maliciously
  ::  submitting txs.
  ?>  ?=(^ -.raw1)
  =.  id.raw1
    [p (dec p) (dec p) (dec p) (dec p)]
  ::
  ::  create second raw-tx to twiddle
  =/  raw2=raw-tx:t
    (simple-from-note:new:raw-tx:v0:t p:default-keys-2:h coin1 s:default-keys-1:h)
  ::
  ::  twiddle coinbase lock to be out of field, we want run a based check
  ::  that is deep inside of of the tx structure
  ?>  ?=(^ -.raw2)
  =/  ips=inputs:t
    =/  inps  ~(tap z-by inputs.raw2)
    ?>  =(1 (lent inps))
    =/  [=nname:t =$>(%0 input:t)]  =-  [-< [%0 ->]]  (snag 0 inps)
    =/  seds  ~(tap z-in seeds.spend.input)
    ?>  =(1 (lent seds))
    =/  sed  (snag 0 seds)
    =.  timelock-intent.sed  `[[`0 ``@ud`p] [~ ~]]
    %+  ~(put z-by *inputs:t)
      nname
    input(seeds.spend (~(put z-in *(z-set seed:t)) sed))
  =.  inputs.raw2  (into:v0:inputs:t ips)
  %+  weld
    %+  expect-eq
      !>(%.n)
    !>((based:raw-tx:t raw1))
  %+  expect-eq
    !>(%.n)
  !>((based:raw-tx:t raw2))
::
++  test-spend-coinbase-after-timelock
  =/  con=consensus-state  initial-consensus-state:h
  =^  par=page:t  con  (add-n-pages:h 101 con default-retain:h)
  ::
  =/  new-page=page:t  (make-empty-page:h par)
  ::
  =/  =tx:t  (new:tx:t (make-default-coinbase-raw-tx:v0:h p:default-keys-2:h) 102)
  ?>  ?=(^ -.raw-tx.tx)
  =.  new-page
    ?^  -.new-page
      %=  new-page
        tx-ids  (~(put z-in *(z-set tx-id:t)) ~(id get:raw-tx:t raw-tx.tx))
      ==
    %=  new-page
      tx-ids  (~(put z-in *(z-set tx-id:t)) ~(id get:raw-tx:t raw-tx.tx))
    ==
  =.  new-page
    ?^  -.new-page
      %=  new-page
        digest  (compute-digest:page:t new-page)
      ==
    %=  new-page
      digest  (compute-digest:page:t new-page)
    ==
  =^  ready  con  (~(add-raw-tx dcon con constants) raw-tx.tx)
  ?>  -:(~(validate-page-without-txs dcon con constants) new-page ~(timestamp get:page:t new-page))
  ::
  =/  tac  (~(validate-page-with-txs dcon con constants) new-page)
  ?:  ?=(%.n -.tac)
    (expect !>(%.n))
  =.  con  (~(accept-page dcon con constants) new-page +.tac *@da)
  =.  con  (~(update-heaviest dcon con constants) new-page)
  =/  old-in-balance=?
    (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t make-default-coinbase:v0:h))
  =/  outs=outputs:t  ~(outputs get:tx:t tx)
  ?>  ?=(%0 -.outs)
  =/  new-note=nnote:t
    note:(~(got z-by +.outs) p:default-keys-2:h)
  ?>  ?=(^ -.new-note)
  =/  new-in-balance=?
    (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t new-note))
  %+  expect-eq
    !>  [%.n %.y]
  !>  [old-in-balance new-in-balance]
::
++  test-double-spend-coinbase-after-timelock
  =/  con=consensus-state  initial-consensus-state:h
  =^  par=page:t  con  (add-n-pages:h 101 con default-retain:h)
  =/  new-page=page:t  (make-empty-page:h par)
  ::
  =/  tx1=tx:t  (new:tx:t (make-default-coinbase-raw-tx:v0:h p:default-keys-2:h) 102)
  =/  tx2=tx:t  (new:tx:t (make-default-coinbase-raw-tx:v0:h p:default-keys-3:h) 102)
  ?>  ?=(^ -.raw-tx.tx1)
  ?>  ?=(^ -.raw-tx.tx2)
  =.  new-page
    ?^  -.new-page
      %=  new-page
        tx-ids  (~(gas z-in *(z-set tx-id:t)) ~[id.raw-tx.tx1 id.raw-tx.tx2])
      ==
    %=  new-page
      tx-ids  (~(gas z-in *(z-set tx-id:t)) ~[id.raw-tx.tx1 id.raw-tx.tx2])
    ==
  =.  new-page
    ?^  -.new-page
      %=  new-page
        digest  (compute-digest:page:t new-page)
      ==
    %=  new-page
      digest  (compute-digest:page:t new-page)
    ==
  =^  ready  con  (~(add-raw-tx dcon con constants) raw-tx.tx1)
  =^  ready  con  (~(add-raw-tx dcon con constants) raw-tx.tx2)
  ?>  -:(~(validate-page-without-txs dcon con constants) new-page ~(timestamp get:page:t new-page))
  ::
  =/  tac  -:(~(validate-page-with-txs dcon con constants) new-page)
  %+  expect-eq
    !>(%.n)
  !>(tac)
::
::  assets spent must be exactly equal to assets in the note. if you
::  try to construct a raw-tx where this is not the case, it should fail.
++  test-single-utxo-invalid-spend-construction-fail
  =/  =coinbase:t  make-default-coinbase:v0:h
  ?>  ?=(^ -.coinbase)
  ::
  ::  Overspend from note
  =/  seed1=seed:t
    %*  .  *seed:t
      gift  +(assets.coinbase)
      recipient  p:default-keys-2:h
      parent-hash  (hash:nnote:t coinbase)
    ==
  ::  Underspend from note
  =/  seed2=seed:t
    seed1(gift (dec assets.coinbase))
  =/  inp1=$>(%0 input:t)
    ($:new:v0:input:t coinbase (~(put z-in *seeds:t) seed1) 0 s:default-keys-1:h)
  =/  inp2=$>(%0 input:t)
    ($:new:v0:input:t coinbase (~(put z-in *seeds:t) seed2) 0 s:default-keys-1:h)
  =/  ips1=inputs:t
    (new:v0:inputs:t inp1)
  =/  ips2=inputs:t
    (new:v0:inputs:t inp2)
  =/  raw1  (mole |.((from-inputs:v0:raw-tx:t ips1)))
  =/  raw2  (mole |.((from-inputs:v0:raw-tx:t ips2)))
  %+  expect-eq
    !>([~ ~])  :: should fail to build invalid transactions
  !>([raw1 raw2])
::
++  test-two-to-one-utxo-spend
  =/  con=consensus-state  initial-consensus-state:h
  =^  page1=page:t  con  (add-n-pages:h 1 con default-retain:h)
  =^  page2=page:t  con  (add-n-pages:h 1 con default-retain:h)
  ::
  =/  coin1=coinbase:t  (new:v0:coinbase:t page1 p:default-keys-1:h)
  ?>  ?=(^ -.coin1)
  =/  coin2=coinbase:t  (new:v0:coinbase:t page2 p:default-keys-1:h)
  ?>  ?=(^ -.coin2)
  =^  last-page  con  (add-n-pages:h 101 con default-retain:h)
  ::  two inputs -> one output
  =/  inp1=$>(%0 input:t)
    (simple-from-note:new:v0:input:t p:default-keys-2:h coin1 s:default-keys-1:h)
  =/  inp2=$>(%0 input:t)
    (simple-from-note:new:v0:input:t p:default-keys-2:h coin2 s:default-keys-1:h)
  =/  ips=inputs:t  (multi:new:v0:inputs:t ~[inp1 inp2])
  =/  raw=raw-tx:t  (from-inputs:v0:raw-tx:t ips)
  ::
  =/  new-page=page:t  (make-empty-page:h last-page)
  =/  =tx:t  (new:tx:t raw ~(height get:page:t new-page))
  ?>  ?=(^ -.raw-tx.tx)
  =.  new-page
    ?^  -.new-page
      %=  new-page
        tx-ids  (~(put z-in *(z-set tx-id:t)) ~(id get:raw-tx:t raw-tx.tx))
      ==
    %=  new-page
      tx-ids  (~(put z-in *(z-set tx-id:t)) ~(id get:raw-tx:t raw-tx.tx))
    ==
  =.  new-page
    ?^  -.new-page
      %=  new-page
        digest  (compute-digest:page:t new-page)
      ==
    %=  new-page
      digest  (compute-digest:page:t new-page)
    ==
  =^  ready  con  (~(add-raw-tx dcon con constants) raw-tx.tx)
  ?>  -:(~(validate-page-without-txs dcon con constants) new-page ~(timestamp get:page:t new-page))
  ::
  =/  tac  (~(validate-page-with-txs dcon con constants) new-page)
  ?:  ?=(%.n -.tac)
    (expect !>(%.n))
  =.  con  (~(accept-page dcon con constants) new-page +.tac *@da)
  =.  con  (~(update-heaviest dcon con constants) new-page)
  =/  old-in-balance=?
    ?|  (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t coin1))
        (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t coin2))
    ==
  =/  outs=outputs:t  ~(outputs get:tx:t tx)
  ?>  ?=(%0 -.outs)
  =/  new-note=nnote:t
    note:(~(got z-by +.outs) p:default-keys-2:h)
  ?>  ?=(^ -.new-note)
  =/  new-in-balance=?
    (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t new-note))
  %+  expect-eq
    !>  [%.n %.y]
  !>  [old-in-balance new-in-balance]
::
++  test-three-to-one-utxo-spend
  =/  con=consensus-state  initial-consensus-state:h
  =^  page1=page:t  con  (add-n-pages:h 1 con default-retain:h)
  =^  page2=page:t  con  (add-n-pages:h 1 con default-retain:h)
  =^  page3=page:t  con  (add-n-pages:h 1 con default-retain:h)
  ::

  =/  coin1=coinbase:t  (new:v0:coinbase:t page1 p:default-keys-1:h)
  ?>  ?=(^ -.coin1)
  =/  coin2=coinbase:t  (new:v0:coinbase:t page2 p:default-keys-1:h)
  ?>  ?=(^ -.coin2)
  =/  coin3=coinbase:t  (new:v0:coinbase:t page3 p:default-keys-1:h)
  ?>  ?=(^ -.coin3)
  =^  last-page  con  (add-n-pages:h 101 con default-retain:h)
  ::  three inputs -> one output
  =/  inp1=$>(%0 input:t)
    (simple-from-note:new:v0:input:t p:default-keys-2:h coin1 s:default-keys-1:h)
  =/  inp2=$>(%0 input:t)
    (simple-from-note:new:v0:input:t p:default-keys-2:h coin2 s:default-keys-1:h)
  =/  inp3=$>(%0 input:t)
    (simple-from-note:new:v0:input:t p:default-keys-2:h coin3 s:default-keys-1:h)
  =/  ips=inputs:t  (multi:new:v0:inputs:t ~[inp1 inp2 inp3])
  =/  raw=raw-tx:t  (from-inputs:v0:raw-tx:t ips)
  ::
  =/  new-page=page:t  (make-empty-page:h last-page)
  =/  =tx:t  (new:tx:t raw ~(height get:page:t new-page))
  ?>  ?=(^ -.raw-tx.tx)
  =.  new-page
    ?^  -.new-page
      %=  new-page
        tx-ids  (~(put z-in *(z-set tx-id:t)) ~(id get:raw-tx:t raw-tx.tx))
      ==
    %=  new-page
      tx-ids  (~(put z-in *(z-set tx-id:t)) ~(id get:raw-tx:t raw-tx.tx))
    ==
  =.  new-page
    ?^  -.new-page
      %=  new-page
        digest  (compute-digest:page:t new-page)
      ==
    %=  new-page
      digest  (compute-digest:page:t new-page)
    ==
  =^  ready  con  (~(add-raw-tx dcon con constants) raw-tx.tx)
  ?>  -:(~(validate-page-without-txs dcon con constants) new-page ~(timestamp get:page:t new-page))
  ::
  =/  tac  (~(validate-page-with-txs dcon con constants) new-page)
  ?:  ?=(%.n -.tac)  (expect !>(%.n))
  =.  con  (~(accept-page dcon con constants) new-page +.tac *@da)
  =.  con  (~(update-heaviest dcon con constants) new-page)
  =/  old-in-balance=?
    ?|  (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t coin1))
        (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t coin2))
        (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t coin3))
    ==
  =/  outs=outputs:t  ~(outputs get:tx:t tx)
  ?>  ?=(%0 -.outs)
  =/  new-note=nnote:t
    note:(~(got z-by +.outs) p:default-keys-2:h)
  ?>  ?=(^ -.new-note)
  =/  new-in-balance=?
    (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t new-note))
  %+  expect-eq
    !>  [%.n %.y]
  !>  [old-in-balance new-in-balance]
::
++  test-one-to-two-utxo-spend
  =/  con=consensus-state  initial-consensus-state:h
  =^  page1=page:t  con  (add-n-pages:h 1 con default-retain:h)
  =/  coin1=coinbase:t  (new:v0:coinbase:t page1 p:default-keys-1:h)
  ?>  ?=(^ -.coin1)
  =^  last-page=page:t  con  (add-n-pages:h 101 con default-retain:h)
  ::
  =/  seed1=seed:t
    %*  .  *seed:t
      gift  (dec assets.coin1)
      recipient  p:default-keys-2:h
      parent-hash  (hash:nnote:t coin1)
    ==
  =/  seed2=seed:t
    %*  .  *seed:t
      gift  1
      recipient  p:default-keys-3:h
      parent-hash  (hash:nnote:t coin1)
    ==
  ::  one inputs -> two outputs
  =/  inp1=$>(%0 input:t)
    ($:new:v0:input:t coin1 (~(gas z-in *seeds:t) ~[seed1 seed2]) 0 s:default-keys-1:h)
  =/  ips=inputs:t  (new:v0:inputs:t inp1)
  =/  raw=raw-tx:t  (from-inputs:v0:raw-tx:t ips)
  ::
  =/  new-page=page:t  (make-empty-page:h last-page)
  =/  =tx:t  (new:tx:t raw ~(height get:page:t new-page))
  ?>  ?=(^ -.raw-tx.tx)
  =.  new-page
    ?^  -.new-page
      %=  new-page
        tx-ids  (~(put z-in *(z-set tx-id:t)) ~(id get:raw-tx:t raw-tx.tx))
      ==
    %=  new-page
      tx-ids  (~(put z-in *(z-set tx-id:t)) ~(id get:raw-tx:t raw-tx.tx))
    ==
  =.  new-page
    ?^  -.new-page
      %=  new-page
        digest  (compute-digest:page:t new-page)
      ==
    %=  new-page
      digest  (compute-digest:page:t new-page)
    ==
  =^  ready  con  (~(add-raw-tx dcon con constants) raw-tx.tx)
  ?>  -:(~(validate-page-without-txs dcon con constants) new-page ~(timestamp get:page:t new-page))
  ::
  =/  tac  (~(validate-page-with-txs dcon con constants) new-page)
  ?:  ?=(%.n -.tac)  (expect !>(%.n))
  =.  con  (~(accept-page dcon con constants) new-page +.tac *@da)
  =.  con  (~(update-heaviest dcon con constants) new-page)
  =/  old-in-balance=?
    (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t coin1))
  =/  outs=outputs:t  ~(outputs get:tx:t tx)
  ?>  ?=(%0 -.outs)
  =/  new-note1=nnote:t
    note:(~(got z-by +.outs) p:default-keys-2:h)
  =/  new-note2=nnote:t
    note:(~(got z-by +.outs) p:default-keys-3:h)
  ?>  ?=(^ -.new-note1)
  ?>  ?=(^ -.new-note2)
  =/  new-in-balance=?
    ?&  (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t new-note1))
        (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t new-note2))
    ==
  %+  expect-eq
    !>  [%.n %.y (dec assets.coin1) 1]
  !>  [old-in-balance new-in-balance assets.new-note1 assets.new-note2]
::
++  test-one-to-three-utxo-spend
  =/  con=consensus-state  initial-consensus-state:h
  =^  page1=page:t  con  (add-n-pages:h 1 con default-retain:h)
  =/  coin1=coinbase:t  (new:v0:coinbase:t page1 p:default-keys-1:h)
  ?>  ?=(^ -.coin1)
  =^  last-page=page:t  con  (add-n-pages:h 101 con default-retain:h)
  ::
  =/  seed1=seed:t
    %*  .  *seed:t
      gift  (sub assets.coin1 3)
      recipient  p:default-keys-2:h
      parent-hash  (hash:nnote:t coin1)
    ==
  =/  seed2=seed:t
    %*  .  *seed:t
      gift  1
      recipient  p:default-keys-3:h
      parent-hash  (hash:nnote:t coin1)
    ==
  =/  seed3=seed:t
    %*  .  *seed:t
      gift  2
      recipient  p:default-keys-1:h
      parent-hash  (hash:nnote:t coin1)
    ==
  ::  one input -> three outputs
  =/  inp1=$>(%0 input:t)  ($:new:v0:input:t coin1 (~(gas z-in *seeds:t) ~[seed1 seed2 seed3]) 0 s:default-keys-1:h)
  =/  ips=inputs:t  (new:v0:inputs:t inp1)
  =/  raw=raw-tx:t  (from-inputs:v0:raw-tx:t ips)
  ::
  =/  new-page=page:t  (make-empty-page:h last-page)
  =/  =tx:t  (new:tx:t raw ~(height get:page:t new-page))
  ?>  ?=(^ -.raw-tx.tx)
  =.  new-page
    ?^  -.new-page
      %=  new-page
        tx-ids  (~(put z-in *(z-set tx-id:t)) ~(id get:raw-tx:t raw-tx.tx))
      ==
    %=  new-page
      tx-ids  (~(put z-in *(z-set tx-id:t)) ~(id get:raw-tx:t raw-tx.tx))
    ==
  =.  new-page
    ?^  -.new-page
      %=  new-page
        digest  (compute-digest:page:t new-page)
      ==
    %=  new-page
      digest  (compute-digest:page:t new-page)
    ==
  =^  ready  con  (~(add-raw-tx dcon con constants) raw-tx.tx)
  ~&  >>  constants+constants
  =/  valid=(reason ~)  (~(validate-page-without-txs dcon con constants) new-page ~(timestamp get:page:t new-page))
  ?.  -.valid
    ~&  >>  [%failed-reason +:valid]  !!
  ::
  =/  tac  (~(validate-page-with-txs dcon con constants) new-page)
  ?:  ?=(%.n -.tac)  (expect !>(%.n))
  =.  con  (~(accept-page dcon con constants) new-page +.tac *@da)
  =.  con  (~(update-heaviest dcon con constants) new-page)
  =/  old-in-balance=?
    (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t coin1))
  =/  outs=outputs:t  ~(outputs get:tx:t tx)
  ?>  ?=(%0 -.outs)
  =/  new-note1=nnote:t
    note:(~(got z-by +.outs) p:default-keys-2:h)
  =/  new-note2=nnote:t
    note:(~(got z-by +.outs) p:default-keys-3:h)
  =/  new-note3=nnote:t
    note:(~(got z-by +.outs) p:default-keys-1:h)
  ?>  ?=(^ -.new-note1)
  ?>  ?=(^ -.new-note2)
  ?>  ?=(^ -.new-note3)
  =/  new-in-balance=?
    ?&  (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t new-note1))
        (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t new-note2))
        (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t new-note3))
    ==
  %+  expect-eq
    !>  [%.n %.y (sub assets.coin1 3) 1 2]
  !>  :*  old-in-balance
          new-in-balance
          assets.new-note1
          assets.new-note2
          assets.new-note3
      ==
::
++  test-two-to-two-utxo-sp  ::
  =/  con=consensus-state  initial-consensus-state:h
  =^  page1=page:t  con  (add-n-pages:h 1 con default-retain:h)
  =/  coin1=coinbase:t  (new:v0:coinbase:t page1 p:default-keys-1:h)
  ?>  ?=(^ -.coin1)
  =^  page2=page:t  con  (add-n-pages:h 1 con default-retain:h)
  =/  coin2=coinbase:t  (new:v0:coinbase:t page2 p:default-keys-1:h)
  ?>  ?=(^ -.coin2)
  =^  last-page=page:t  con  (add-n-pages:h 101 con default-retain:h)
  ::
  ::  one inputs -> two outputs
  =/  inp1=$>(%0 input:t)
    (simple-from-note:new:v0:input:t p:default-keys-2:h coin1 s:default-keys-1:h)
  =/  inp2=$>(%0 input:t)
    (simple-from-note:new:v0:input:t p:default-keys-3:h coin2 s:default-keys-1:h)
  =/  ips=inputs:t  (multi:new:v0:inputs:t ~[inp1 inp2])
  =/  raw=raw-tx:t  (from-inputs:v0:raw-tx:t ips)
  ::
  =/  new-page=page:t  (make-empty-page:h last-page)
  =/  =tx:t  (new:tx:t raw ~(height get:page:t new-page))
  ?>  ?=(^ -.raw-tx.tx)
  =.  new-page
    ?^  -.new-page
      %=  new-page
        tx-ids  (~(put z-in *(z-set tx-id:t)) ~(id get:raw-tx:t raw-tx.tx))
      ==
    %=  new-page
      tx-ids  (~(put z-in *(z-set tx-id:t)) ~(id get:raw-tx:t raw-tx.tx))
    ==
  =.  new-page
    ?^  -.new-page
      %=  new-page
        digest  (compute-digest:page:t new-page)
      ==
    %=  new-page
      digest  (compute-digest:page:t new-page)
    ==
  =^  ready  con  (~(add-raw-tx dcon con constants) raw-tx.tx)
  ?>  -:(~(validate-page-without-txs dcon con constants) new-page ~(timestamp get:page:t new-page))
  ::
  =/  tac  (~(validate-page-with-txs dcon con constants) new-page)
  ?:  ?=(%.n -.tac)
    (expect !>(%.n))
  =.  con  (~(accept-page dcon con constants) new-page +.tac *@da)
  =.  con  (~(update-heaviest dcon con constants) new-page)
  =/  old-in-balance=?
    ?|  (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t coin1))
        (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t coin2))
    ==
  =/  outs=outputs:t  ~(outputs get:tx:t tx)
  ?>  ?=(%0 -.outs)
  =/  new-note1=nnote:t
    note:(~(got z-by +.outs) p:default-keys-2:h)
  =/  new-note2=nnote:t
    note:(~(got z-by +.outs) p:default-keys-3:h)
  ?>  ?=(^ -.new-note1)
  ?>  ?=(^ -.new-note2)
  =/  new-in-balance=?
    ?&  (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t new-note1))
        (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t new-note2))
    ==
  %+  expect-eq
    !>  [%.n %.y assets.coin1 assets.coin2]
  !>  [old-in-balance new-in-balance assets.new-note1 assets.new-note2]
