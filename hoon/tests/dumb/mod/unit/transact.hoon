++  test-a-pt-conversion
  =/  a-pt-expect=(list a-pt:curve:cheetah)
    :~  default-a-pt-1:h
        default-a-pt-2:h
        default-a-pt-3:h
    ==
  =/  a-pt-actual=(list a-pt:curve:cheetah)
    %+  turn  a-pt-expect
    |=  a=a-pt:curve:cheetah
    ^-  a-pt:curve:cheetah
    (base58-to-a-pt:cheetah (a-pt-to-base58:cheetah a))
  ::
  %+  expect-eq
    !>(a-pt-expect)
  !>(a-pt-actual)
