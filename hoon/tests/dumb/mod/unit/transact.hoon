++  test-schnorr-pubkey-conversion
  ::  this just calls the same arms as test-a-pt-conversion but we do a separate test anyways to ensure those arms dont break
  =/  pk-expect=(list sig:t)
    :~  p:default-keys-1:h
        p:default-keys-2:h
        p:default-keys-3:h
    ==
  =/  pk-actual=(list sig:t)
    %+  turn  pk-expect
    |=  pk=sig:t
    ^-  sig:t
    (from-b58:sig:t (to-b58:sig:t pk))
  ::
  %+  expect-eq
    !>(pk-expect)
  !>(pk-actual)
::
++  test-coinbase-split-fibonacci
  =/  total=coins:t  999.999.999
  =/  shares=(z-map sig:t @)
    (~(gas z-by *(z-map sig:t @)) ~[[p:default-keys-1:h 21] [p:default-keys-2:h 13]])
  =/  split=coinbase-split:v0:t
    (new:coinbase-split:v0:t total shares)
  =/  sum=coins:t
    %+  roll  ~(val z-by split)
    |=  [c=coins:t sum=coins:t]
    (add c sum)
  %+  expect-eq
    !>  :*  total
            617.647.058
            382.352.941
        ==
  !>  :*  sum
          (~(got z-by split) p:default-keys-1:h)
          (~(got z-by split) p:default-keys-2:h)
      ==
::
++  test-block-id-b58-conversion
  ::  test block-id conversion to/from base58 along with to-list and list-to-tuple conversion
  =/  bid-string=@t  'DfPNrKYEzZgnxBAgiSeqz3D8dKYKTtyQ8z98TRKH94Bhv49qhHdHpKy'
  =/  bid=block-id:t  (from-b58:block-id:t bid-string)
