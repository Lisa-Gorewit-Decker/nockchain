++  test-multisig-valid-output-2-of-2
  =/  con=consensus-state  initial-consensus-state:h
  =^  par=page:t  con  (add-n-pages:h 101 con default-retain:h)
  ::
  =/  new-page=page:t  (make-empty-page:h par)
  ::
  =/  =sig:t
    (join:sig:t 2 ~[p:default-keys-1:h p:default-keys-2:h])
  =/  =tx:t  (new:tx:t (make-default-coinbase-raw-tx:v0:h sig) 102)
  ?>  ?=(^ -.raw-tx.tx)
  =.  new-page
    ?^  -.new-page
      %=  new-page
        tx-ids  (~(put z-in *(z-set tx-id:t)) ~(id get:raw-tx:t raw-tx.tx))
      ==
    %=  new-page
      tx-ids  (~(put z-in *(z-set tx-id:t)) ~(id get:raw-tx:t raw-tx.tx))
    ==
  =.  new-page
    ?^  -.new-page
      %=  new-page
        digest  (compute-digest:page:t new-page)
      ==
    %=  new-page
      digest  (compute-digest:page:t new-page)
    ==
  =^  ready  con  (~(add-raw-tx dcon con constants) raw-tx.tx)
  ?>  -:(~(validate-page-without-txs dcon con constants) new-page ~(timestamp get:page:t new-page))
  ::
  =/  tac  (~(validate-page-with-txs dcon con constants) new-page)
  ?:  ?=(%.n -.tac)  (expect !>(%.n))
  =.  con  (~(accept-page dcon con constants) new-page +.tac *@da)
  =.  con  (~(update-heaviest dcon con constants) new-page)
  =/  old-in-balance=?
    (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t make-default-coinbase:v0:h))
  =/  outs=outputs:t  ~(outputs get:tx:t tx)
  ?>  ?=(%0 -.outs)
  =/  new-note=nnote:t
    note:(~(got z-by +.outs) sig)
  ?>  ?=(^ -.new-note)
  =/  new-in-balance=?
    (~(has h-bi balance.con) ~(digest get:page:t new-page) ~(name get:nnote:t new-note))
  %+  expect-eq
    !>  [%.n %.y]
  !>  [old-in-balance new-in-balance]
