++  test-reject-block-parent-epoch-counter
  =/  con=consensus-state  (initial-consensus-state-custom:h constants)
  =^  par=page:t  con  (add-n-pages:h (dec blocks-per-epoch:constants) con default-retain:h)
  =/  new-epoch-counter-par  blocks-per-epoch:constants
  =.  par
    ?^  -.par
      par(epoch-counter new-epoch-counter-par)
    par(epoch-counter new-epoch-counter-par)
  =/  old-digest  ~(digest get:page:t par)
  =/  new-digest-par  (compute-digest:page:t par)
  =.  par
    ?^  -.par
      par(digest new-digest-par)
    par(digest new-digest-par)
  =.  blocks.con  (~(put h-by blocks.con) ~(digest get:page:t par) (to-local-page:page:t par))
  =/  min  (~(got h-by min-timestamps.con) old-digest)
  =.  min-timestamps.con  (~(put h-by min-timestamps.con) ~(digest get:page:t par) min)
  =/  new-page=page:t  (make-empty-page:h par)
  ::  this is to fake the check-target since make-empty-page doesn't know
  ::  about epoch boundaries
  =.  targets.con  (~(put h-by targets.con) ~(digest get:page:t par) ~(target get:page:t new-page))
  ::
  =/  new-page=page:t  (make-empty-page:h par)
  %+  expect-eq  !>(%.n)
  !>(-:(~(validate-page-without-txs dcon con constants) new-page (add 600 ~(timestamp get:page:t par))))
