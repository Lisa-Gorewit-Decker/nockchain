++  test-three-to-two-utxo-spend
  =/  con=consensus-state  initial-consensus-state:h
  =^  page1=page:t  con  (add-n-pages:h 1 con default-retain:h)
  =/  coin1=coinbase:t  (new:v0:coinbase:t page1 p:default-keys-1:h)
