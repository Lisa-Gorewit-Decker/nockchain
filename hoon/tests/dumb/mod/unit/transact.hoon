++  test-no-ready-blocks
  =/  con=consensus-state  initial-consensus-state:h
  =^  par=page:t  con  (add-n-pages:h 1 con default-retain:h)
  ::  make tx
  =/  =tx:t  (new:tx:t (make-default-coinbase-raw-tx:v0:h p:default-keys-2:h) 2)
  ::
  =/  tx2=tx:t  (new:tx:t (make-default-coinbase-raw-tx:v0:h p:default-keys-3:h) 2)
  ?>  ?=(^ -.raw-tx.tx)
  ::
  ::  make new page with tx
  =/  new-page=page:t  (make-empty-page:h par)
  =.  new-page
    ?^  -.new-page
      %=  new-page
        tx-ids  (~(put z-in *(z-set tx-id:t)) ~(id get:raw-tx:t raw-tx.tx))
      ==
    %=  new-page
      tx-ids  (~(put z-in *(z-set tx-id:t)) ~(id get:raw-tx:t raw-tx.tx))
    ==
  =.  new-page
    ?^  -.new-page
      %=  new-page
        digest  (compute-digest:page:t new-page)
      ==
    %=  new-page
      digest  (compute-digest:page:t new-page)
    ==
  ::
  ::  add block to pending state
  =^  miss  con  (~(add-pending-block dcon con constants) new-page)
  ::
  ::
  =^  ready  con  (~(add-raw-tx dcon con constants) raw-tx.tx2)
  ::
  ::  dont add tx to pending state
  =/  expect-ready  ~
  ::
  %+  expect-eq
    !>  expect-ready
  !>  ready
::
::  +test-target-adjustment:
::
::    practically this is just a test for +chunk and +merge right now,
::    since we're just testing a formula of the form (p*d)/e. but
::    once we compute adjustments using bignum arithmetic, this will
::    be more useful.
++  test-target-adjustment
  |^
  =/  bn  bignum
  =/  compute-target-atoms-samples=(list [@ @])
    %-  zing
    %+  turn  epoch-durs-list:h
    |=  dur=@
    %+  turn  initial-atom-targets:h
    |=(tar=@ dur^tar)
  =/  compute-targets-bignum-samples=(list [@ bignum:bn])
    %-  zing
    %+  turn  epoch-durs-list:h
    |=  dur=@
    %+  turn  initial-bignum-targets:h
    |=(tar=bignum:bn dur^tar)
  ::
  ::  turn expected targets into atoms
  =/  expect-target-atoms=(list @)
    (turn compute-target-atoms-samples compute-target-raw-atom)
  =/  actual-target-bignums=(list @)
    %+  turn
      %+  turn  compute-targets-bignum-samples
      ~(compute-target-raw dcon *consensus-state constants)
    merge:bn
  =/  bad  (compare-lists expect-target-atoms actual-target-bignums)
  %+  expect-eq  !>(expect-target-atoms)
  !>(actual-target-bignums)
  ::
  ::  +compute-target-raw-atom
  ::
  ::    same as +compute-target but done entirely with atoms
  ++  compute-target-raw-atom
    |=  [epoch-dur=@ prev-target=@]
    ^-  @
    =/  capped-epoch-dur=@
      ?:  (lth epoch-dur quarter-ted:t)
        quarter-ted:t
      ?:  (gth epoch-dur quadruple-ted:t)
        quadruple-ted:t
      epoch-dur
    =/  next-target=@
      %+  div
        (mul prev-target capped-epoch-dur)
      target-epoch-duration:t
    ?:  (gth next-target max-target-atom:t)
      max-target-atom:t
    next-target
  ::
  ++  compare-lists
    |=  [a=(list @) b=(list @)]
    ?>  =((lent a) (lent b))
    =|  i=@
    =|  bad=(list @)
    |-
    ?~  a  bad
    ?~  b  bad
    ?:  =(i.a i.b)
      $(a t.a, b t.b, i +(i))
    ~&  [%bad-pair i.a i.b %index i]
    $(a t.a, b t.b, bad [i bad], i +(i))
  --
::
++  test-chunk-merge
  =/  bn  bignum
  =/  p=@  +((div max-target-atom:t 8))
  ::
  =/  num=@  p
  =/  big=@  (merge:bn (chunk:bn p))
  %+  expect-eq  !>(num)
  !>(big)
::
++  test-accumulated-work-genesis
  =/  expect-work=@  (div max-target-atom:t +(genesis-target-atom:t))
  %+  expect-eq  !>(expect-work)
  !>((merge:bignum ~(accumulated-work get:page:t default-genesis-page:h)))
