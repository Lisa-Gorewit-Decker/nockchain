  =^  par=page:t  con  (add-n-pages:h 1 con default-retain:h)
  ::
  =/  new-page=page:t  (make-empty-page:h par)
  =/  new-epoch-counter  +(~(epoch-counter get:page:t new-page))
  =.  new-page
    ?^  -.new-page
      new-page(epoch-counter new-epoch-counter)
    new-page(epoch-counter new-epoch-counter)
  =.  new-page
    ?^  -.new-page
      %=  new-page
        digest  (compute-digest:page:t new-page)
      ==
    %=  new-page
