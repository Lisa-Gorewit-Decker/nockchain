++  test-seed-simple-from-note-with-choice-refund
  =/  =coinbase:t  make-default-coinbase:v0:h
  ?>  ?=(^ -.coinbase)
  =.  coinbase  coinbase(assets 3)
  =/  seds=seeds:t
    %:  with-choice:simple-from-note-with-refund:new:seeds:t
        recipient=p:default-keys-2:h
        gift=1
        fee=0
        note=coinbase
        refund-address=p:default-keys-3:h
    ==
  =/  seedz=(list seed:t)  ~(tap z-in seds)
  ?>  =(2 (lent seedz))
  ::
  ::  All of this code below is to determine which seed is the refund
  ::  and which seed is the gift.
  =/  sed1=seed:t  (snag 0 seedz)
  =/  sed2=seed:t  (snag 1 seedz)
  =/  [num-refund=@ refund-seed=seed:t]
    ?:  =(recipient.sed1 p:default-keys-3:h)
      [%1 sed1]
    ?:  =(recipient.sed2 p:default-keys-3:h)
      [%2 sed2]
    !!
  =/  gift-seed
    ?:  ?=(%1 num-refund)
      sed2
    sed1
  ::  Now that we determined which is the refund and gift, we check
  ::  for correctness.
  %+  expect-eq
    !>(%.y)
  !>  ?&  =(gift:refund-seed 2)
          =(parent-hash:refund-seed (hash:nnote:t coinbase))
          =(recipient.refund-seed p:default-keys-3:h)
        ::
          =(gift:gift-seed 1)
          =(parent-hash:gift-seed (hash:nnote:t coinbase))
          =(recipient.gift-seed p:default-keys-2:h)
      ==
::
